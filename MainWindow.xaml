<Window
    x:Class="MetarViewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="METAR Viewer">

    <Grid
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        RequestedTheme="{x:Bind ViewModel.CurrentTheme, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area with Theme Toggle -->
        <Border
            Grid.Row="0"
            Padding="20,16"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="METAR Viewer"
                    Style="{StaticResource TitleTextBlockStyle}"
                    VerticalAlignment="Center"/>

                <Button
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.ToggleThemeCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="{x:Bind ViewModel.ThemeToggleToolTip, Mode=OneWay}">
                    <TextBlock
                        Text="{x:Bind ViewModel.ThemeToggleGlyph, Mode=OneWay}"
                        FontSize="20"
                        VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="20">
                <StackPanel Spacing="20" MaxWidth="800">

                    <!-- Search Section -->
                    <Border
                        CornerRadius="8"
                        Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                        Padding="20"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Text="Enter Airport"
                                Style="{StaticResource SubtitleTextBlockStyle}"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    x:Name="SearchTextBox"
                                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="ICAO, IATA, or airport name (e.g., EGLL, LHR, London Heathrow)"
                                    Margin="0,0,12,0"
                                    KeyDown="SearchTextBox_KeyDown"/>

                                <Button
                                    Grid.Column="1"
                                    Command="{x:Bind ViewModel.FetchMetarCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    MinWidth="120">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ProgressRing
                                            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                            Width="16"
                                            Height="16"
                                            Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"/>
                                        <TextBlock Text="Get METAR"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Error Message -->
                    <InfoBar
                        Severity="Error"
                        IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                        Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        IsClosable="True"/>

                    <!-- METAR Display Section -->
                    <StackPanel
                        Spacing="20"
                        Visibility="{x:Bind ViewModel.CurrentMetarVisibility, Mode=OneWay}">

                        <!-- Quick Summary Card -->
                        <Border
                            CornerRadius="8"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            Padding="20"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.CurrentMetar.StationId, Mode=OneWay}"
                                            Style="{StaticResource TitleTextBlockStyle}"/>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.ObservationTimeText, Mode=OneWay}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <Border
                                        Grid.Column="1"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Padding="12,6"
                                        VerticalAlignment="Top">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.CurrentMetar.FlightCategory, Mode=OneWay}"
                                            FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <!-- Quick Stats -->
                                <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="Wind" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ViewModel.DecodedWind, Mode=OneWay}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="Visibility" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ViewModel.DecodedVisibility, Mode=OneWay}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="Temperature" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ViewModel.DecodedTemperature, Mode=OneWay}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="Altimeter" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ViewModel.DecodedAltimeter, Mode=OneWay}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                        <TextBlock Text="Clouds" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ViewModel.DecodedClouds, Mode=OneWay}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Raw METAR -->
                        <Border
                            CornerRadius="8"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            Padding="20"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Raw METAR"
                                    Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBox
                                    Text="{x:Bind ViewModel.CurrentMetar.RawMetar, Mode=OneWay}"
                                    IsReadOnly="True"
                                    TextWrapping="Wrap"
                                    FontFamily="Consolas"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Decoded Information -->
                        <Border
                            CornerRadius="8"
                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                            Padding="20"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="16">
                                <TextBlock
                                    Text="Decoded Information"
                                    Style="{StaticResource SubtitleTextBlockStyle}"/>

                                <StackPanel Spacing="12">
                                    <StackPanel>
                                        <TextBlock Text="Flight Category" FontWeight="SemiBold"/>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.FlightCategoryDescription, Mode=OneWay}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Weather" FontWeight="SemiBold"/>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.DecodedWeather, Mode=OneWay}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
